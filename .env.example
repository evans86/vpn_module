# Application
APP_NAME="VPN Service"
APP_ENV=production
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_DEBUG=false
# Канонический домен приложения: вебхуки Telegram, очереди; ссылки в админке на текущем зеркале — на его Host (см. AppServiceProvider).
APP_URL=https://vpn-telegram.com
# Первая ссылка на страницы конфигов ключей (бот, API, уведомления). Обычно «зеркало» для пользователей.
APP_CONFIG_PUBLIC_URL=https://vpnhigh.su
# Если CDN отвечает 405 на любой POST: поддомен на тот же VPS без прокси (серое облако в DNS) + SSL.
# PERSONAL_POST_ORIGIN=https://origin.vpnhigh.su
# Если админ входит через зеркало, а после логина уносит на APP_URL — проверьте APP_MIRROR_URLS / CDN-редирект.
# SESSION_DOMAIN только для нужного режима cookie; общий домен на два разных сайта блокирует сессию на зеркале — чаще оставить пустым.
# SESSION_DOMAIN=.vpnhigh.su
# Legacy: если APP_CONFIG_PUBLIC_URL не задан, подставляется APP_PUBLIC_URL.
# APP_PUBLIC_URL=https://vpnhigh.su
# Запасные зеркала через запятую (пробелы обрежутся). Не дублируйте хост из APP_CONFIG_PUBLIC_URL.
# Пример — два рабочих зеркала:
# APP_MIRROR_URLS=https://vagrus.space,https://link.telegram-planet.ru
APP_MIRROR_URLS=https://link.telegram-planet.ru
APP_TIMEZONE=UTC

# Дополнительный слой: HTTP Basic на весь /admin (оба ключа нужны; иначе отключено)
# ADMIN_HTTP_BASIC_USER=admin
# ADMIN_HTTP_BASIC_PASSWORD=secret
# Уведомление в Telegram после успешного Basic (нужны токен бота и chat_id; иначе не шлём)
# ADMIN_HTTP_BASIC_NOTIFY_TELEGRAM_TOKEN=123456:ABC...
# ADMIN_HTTP_BASIC_NOTIFY_TELEGRAM_CHAT_ID=123456789

# Telegram: главный бот продавцов и вход в личный кабинет.
# TELEGRAM_FATHER_BOT_TOKEN=123456:ABC...
# TELEGRAM_FATHER_BOT_NAME=your_bot_username

# Кэш публичного JSON со списком доменов «без VPN» (/vpn/routing/direct-domains.json), секунды
# VPN_DIRECT_DOMAINS_CACHE_SECONDS=120
# Подсказки # в plain text подписке (split-routing). Для ?format=raw не применяется.
# VPN_SUBSCRIPTION_DIRECT_ROUTING_HINTS=true
# JSON sing-box с split-routing (?format=sing-box / UA sing-box без Hiddify/Karing). false — только plain/Clash.
# VPN_SING_BOX_SUBSCRIPTION_PROFILE=true
#
# Сводная проверка флота (админка → Проверка сети и серверов): с хоста Laravel — ICMP + HTTPS до списков ниже
# (запятая без пробелов в значениях или с пробелами после запятой — оба варианта обрезаются).
# FLEET_PROBE_PANEL_HOSTS=admin.example.com,https://panel2.example.com/dashboard
# Внешнее приложение (хост или несколько через запятую; пусто = не проверять)
# FLEET_PROBE_EXTERNAL_APP_DOMAINS=cursevagrus.ru
# Базовые домены под хостнеймы серверов (запятая; пусто = не проверять)
# FLEET_PROBE_SERVER_ZONE_DOMAINS=kvnfreetest.uk,kvncococ.org
# FLEET_PROBE_OUR_DOMAINS=vpn-telegram.com,link.example.org
# FLEET_PROBE_MERGE_PANELS_FROM_DB=true
# FLEET_PROBE_MERGE_APP_DOMAIN_HOSTS=true
# FLEET_PROBE_PREFER_ICMP=true
# FLEET_PROBE_HTTPS_TIMEOUT=12

# Трафик Gemini / Google API через Cloudflare WARP внутри JSON sing-box (оператор задаёт WireGuard-ключи один раз).
# VPN_SING_BOX_WARP_GEMINI=true
# VPN_SING_BOX_WARP_OUTBOUND_JSON_PATH=storage/app/warp-outbound.json
# либо:
# VPN_SING_BOX_WARP_PRIVATE_KEY=
# VPN_SING_BOX_WARP_LOCAL_ADDRESSES=["172.16.0.2/32","2406:....../128"]
# VPN_SING_BOX_WARP_RESERVED=

# Logging
LOG_CHANNEL=stack
# На проде: только файл, без INSERT в БД на каждый лог (иначе возможны таймауты под нагрузкой)
# LOG_STACK_CHANNELS=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Выгрузка логов Marzban с серверов в Yandex Object Storage (s3cmd; админка → серверы → «Включить выгрузку логов»)
# S3_LOGS_ACCESS_KEY=
# S3_LOGS_SECRET_KEY=
# S3_LOGS_BUCKET=s3://имя-бакета

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpn
DB_USERNAME=root
DB_PASSWORD=

# Cache and Session
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Services
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher/WebSockets
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Панели Marzban: выбор панели для ротации (активация, модуль, мульти-слоты)
# simple — минимум активных пользователей на панели (JOIN key_activate status=ACTIVE, по умолчанию)
# intelligent — прежний score (мониторинг + активные ключи через связи + время)
# PANEL_SELECTION_STRATEGY=simple
# PANEL_SELECTION_CACHE_TTL=90
# PANEL_SELECTION_WARM_ENABLED=true
# PANEL_SELECTION_WARM_EVERY_MINUTES=1
# Кэш страницы «Настройки распределения» (админка) — прогрев: panel:warm-rotation-settings
# PANEL_ROTATION_SETTINGS_CACHE_TTL=900
# PANEL_ROTATION_SETTINGS_WARM_ENABLED=true
# PANEL_ROTATION_SETTINGS_WARM_EVERY_MINUTES=5
# Мульти-слоты: список провайдеров (server.provider) или * / all — весь пул ротации для тарифа (нужны PANEL_SELECTION_V2=true и PANEL_MULTI_PROVIDER_GREEDY=true).
# PANEL_MULTI_PROVIDER_SLOTS=vdsina,timeweb
# PANEL_MULTI_PROVIDER_SLOTS=*
# PANEL_MAX_PROVIDER_SLOTS=3
# PANEL_MULTI_PROVIDER_GREEDY=true
#
# WARP: https://marzban-docs.sm1ky.com/tutorials/cloudflare-warp/
# По умолчанию — auto: нативный WireGuard в Xray, если в БД есть снимок wgcf (после автоустановки WARP на ноде или кнопки «Подтянуть wgcf»), иначе SOCKS. Без ручного .env при автоимпорте.
# PANEL_WARP_OUTBOUND_PROTOCOL=auto
# Вариант 1 — только нативный WireGuard в Xray (ключи в .env из wgcf-profile.conf вручную):
# PANEL_WARP_OUTBOUND_PROTOCOL=wireguard
# PANEL_WARP_WG_SECRET_KEY=
# PANEL_WARP_WG_ADDRESS=172.16.0.2/32,2606:4700:110:…/128
# Если снимок wgcf в БД без IPv4 — можно задать только IPv4 здесь, он подмешивается к address[] при сборке Xray.
# PANEL_WARP_WG_PEER_PUBLIC_KEY=bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=
# PANEL_WARP_WG_ENDPOINT=engage.cloudflareclient.com:2408
# Явная подмена peer на IPv4 (приоритетнее чем ENGAGE_REPLACE). Пусть пустым — см. ENGAGE_REPLACE.
# PANEL_WARP_WG_ENDPOINT_IP=
# Если снимок wgcf даёт engage.cloudflareclient.com и ENDPOINT_IP пуст — заменить на этот IPv4 при применении конфига.
# Пустое значение — не заменять. По умолчанию 162.159.192.1.
# PANEL_WARP_WG_ENGAGE_REPLACE_IPV4=162.159.192.1
# PANEL_WARP_WG_RESERVED=
# PANEL_WARP_WG_NO_KERNEL_TUN=true
# PANEL_WARP_WG_MTU=1420
# Вариант 2 — SOCKS к sing-box на ноде (как в конце статьи):
# PANEL_WARP_OUTBOUND_PROTOCOL=socks
# Порт и хост SOCKS WARP по умолчанию (в карточке панели, если пусто). Marzban в проекте в Docker — чаще 172.17.0.1, не 127.0.0.1
# PANEL_WARP_DEFAULT_SOCKS_PORT=40000
# PANEL_WARP_DEFAULT_SOCKS_HOST=172.17.0.1
# Fallback в UI: чекбокс «все сайты через WARP»
# PANEL_WARP_DEFAULT_ROUTING_ALL=false
# Узкий маршрут: marzban = geosite:google + geosite:openai (как в статье), gemini = список в config/vpn.php
# PANEL_WARP_SELECTIVE_BASE=marzban
# Доп. в узкий WARP, через запятую. geosite: — как в geosite.dat на ноде.
# PANEL_WARP_ROUTING_GEOSITE_EXTRA=
# PANEL_WARP_ROUTING_DOMAIN_EXTRA=
# Если включён «весь трафик через WARP»: DIRECT для этих целей **перед** catch-all (снижает таймауты Telegram и др.)
# PANEL_WARP_FULL_BYPASS_GEOSITE=geosite:telegram
# PANEL_WARP_FULL_BYPASS_IP=149.154.0.0/16,91.108.0.0/16

# Cloudflare DNS: новые A-записи — случайная зона из пула (без vpn-telegram.com).
# CLOUDFLARE_EMAIL= / CLOUDFLARE_API_KEY= — как в панели Cloudflare.
# Старая зона (vpn-telegram.com) — только для удаления записей у серверов без cloudflare_zone_id в БД.
# CLOUDFLARE_LEGACY_ZONE_ID=ecd4115fa760df3dd0a5f9c0e2caee2d
# CLOUDFLARE_DNS_ZONE_KVN_FREE=23ccc49cc28d56e1c2efb0e65f7592df
# CLOUDFLARE_DNS_DOMAIN_KVN_FREE=kvnfreetest.uk
# CLOUDFLARE_DNS_ZONE_KVN_COCO=14e5935e8704782977a1c330fa33795d
# CLOUDFLARE_DNS_DOMAIN_KVN_COCO=kvncococ.org
